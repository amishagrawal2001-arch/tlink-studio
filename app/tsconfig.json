{
    "compilerOptions": {
        "baseUrl": "./src",
        "module": "commonjs",
        "target": "es2022",
        "useDefineForClassFields": false,
        "declaration": false,
        "noImplicitAny": false,
        "removeComments": false,
        "esModuleInterop": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "sourceMap": true,
        "noImplicitReturns": true,
        "noFallthroughCasesInSwitch": true,
        "noUnusedParameters": true,
        "noUnusedLocals": true,
        "lib": [
           "dom",
           "es2022"
        ],
        "types": ["node"]
    },
    "compileOnSave": false,
    "include": [
        "src/**/*",
        "lib/sentry.ts"
    ],
    "exclude": [
        "dist",
        "node_modules",
        "*/node_modules",
        "tlink*",
        "platforms"
    ]
}
